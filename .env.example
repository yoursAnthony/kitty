# Скопируйте этот файл в .env и заполните значениями
# Запуск: cp .env.example .env  (или скопируйте вручную в Windows)

# ── Django ───────────────────────────────────────────────
SECRET_KEY=replace-me-with-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ── База данных (PostgreSQL в docker-compose) ────────────
POSTGRES_DB=kittygram
POSTGRES_USER=kittygram
POSTGRES_PASSWORD=replace-me-strong-password
DB_HOST=db
DB_PORT=5432

# ── Использовать sqlite вместо PostgreSQL для локальной разработки ──
# Если USE_SQLITE=1 — Django подключит db.sqlite3, переменные DB_* игнорируются
USE_SQLITE=0
